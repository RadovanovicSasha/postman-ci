		{
			"name": "Booking",
			"item": [
				{
					"name": "Create Booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// TEST: provera status code-a\r",
									"pm.test(\"Status code is 200\", function () {\r",
									"\r",
									"    // očekujemo HTTP 200 OK\r",
									"    pm.response.to.have.status(200);\r",
									"\r",
									"});\r",
									"\r",
									"\r",
									"// RESPONSE pretvaramo u JSON objekat\r",
									"let jsonData = pm.response.json();\r",
									"\r",
									"\r",
									"// Čuvamo bookingId iz response-a u environment varijablu\r",
									"// koristićemo ga kasnije za GET / PUT / DELETE\r",
									"pm.environment.set(\"bookingId\", jsonData.bookingid);\r",
									"\r",
									"\r",
									"\r",
									"// TEST: provera da li je vraćena ista random cena\r",
									"pm.test(\"Total price matches generated value\", function () {\r",
									"\r",
									"    // response pretvaramo u JSON\r",
									"    let jsonData = pm.response.json();\r",
									"\r",
									"    // proveravamo:\r",
									"    // booking.totalprice iz response-a\r",
									"    // mora biti isti kao randomPrice iz environment-a\r",
									"    pm.expect(jsonData.booking.totalprice)\r",
									"        .to.eql(Number(pm.environment.get(\"randomPrice\")));\r",
									"\r",
									"});\r",
									"\r",
									"\r",
									"\r",
									"// TEST: provera tipa podatka\r",
									"pm.test(\"Total price is a number\", function () {\r",
									"\r",
									"    // response pretvaramo u JSON\r",
									"    let jsonData = pm.response.json();\r",
									"\r",
									"    // proveravamo da li je totalprice number\r",
									"    pm.expect(jsonData.booking.totalprice)\r",
									"        .to.be.a(\"number\");\r",
									"\r",
									"});\r",
									"\r",
									"// TEST: provera da li polje \"firstname\" postoji\r",
									"pm.test(\"Firstname field exists\", function () {\r",
									"\r",
									"    // response pretvaramo u JSON\r",
									"    let jsonData = pm.response.json();\r",
									"\r",
									"    // proveravamo da li booking objekat\r",
									"    // sadrži property \"firstname\"\r",
									"    pm.expect(jsonData.booking)\r",
									"        .to.have.property(\"firstname\");\r",
									"\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Random Name\r",
									"\r",
									"let randomName = \"User_\" + Math.floor(Math.random() * 1000);\r",
									"\r",
									"pm.environment.set(\"randomFirstname\", randomName);\r",
									"\r",
									"// Random ID\r",
									"\r",
									"let timestamp = Date.now();\r",
									"\r",
									"pm.environment.set(\"uniqueId\", timestamp);\r",
									"\r",
									"// Random cene\r",
									"\r",
									"let randomPrice = Math.floor(Math.random() * 500) + 50;\r",
									"\r",
									"pm.environment.set(\"randomPrice\", randomPrice);"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"protocolProfileBehavior": {
						"disabledSystemHeaders": {}
					},
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"firstname\": \"{{randomFirstname}}\",\r\n    \"lastname\": \"Radovanovic_{{uniqueId}}\",\r\n    \"totalprice\": {{randomPrice}},\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-05-10\",\r\n        \"checkout\": \"2026-05-15\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/booking?test=123",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"booking"
							],
							"query": [
								{
									"key": "test",
									"value": "123"
								}
							]
						}
					},
					"response": []
				},
